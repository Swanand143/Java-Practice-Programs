int num = sc.nextInt();
		int max = 0;
		int min = 9;
		for (int i=num; i>0 ;i/=10 )
		{
			int digit = i%10;
			if (max<digit) 
			{
				max = digit;
			}
			else if (min>digit)
			{
				min = digit;
			}
		}
		System.out.println("\nLargest Digit From "+num+" is "+max);
		System.out.println("\nSmallest Digit From "+num+" is "+min);
	}
}

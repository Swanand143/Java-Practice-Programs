PrintSeries3
{
	public static void main(String[] args)
	{
		Scanner sc =new Scanner(System.in);
		System.out.print("Enter a range : ");
		int range = sc.nextInt();
		for (int i=2; i<=range; i++)
		{
			int pow = 1;
			for (int j=1; j<=3 ;j++)
			{
				pow*=i;
			}
			System.out.print((pow+i)+" ");
		}
	}
}
